<% layout("/layouts/boilerplate")%>
    <style>
        #filters {
            align-items: center;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
        }

        .icons {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
        }

        #filters a {
            text-decoration: none;
        }

        .filter {
            margin-right: 2rem;
            margin-top: 2rem;
            text-align: center;
            opacity: 0.7;
            flex-wrap: wrap;
            color: black;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter p {
            font-size: 0.8rem;
        }

        .tax-toggle {
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.25rem;
            padding: 1rem;
            margin-left: 1rem;
        }

        @media screen and (max-width: 476px) {
            .tax-toggle {
                display: none;
            }
        }

        .tax-info {
            display: none;
        }

        .more-icon {
            display: none;
        }
    </style>
    <!-- <body> -->
    <%= msg %>




        <div id="filters">
            <div class="icons">
                <a href="/listings?category=trending">
                    <div class="filter icon-item">
                        <div><i class="fa-solid fa-fire"></i></div>
                        <p>Trending</p>
                    </div>
                </a>
                <a href="/listings?category=rooms">
                    <div class="filter icon-item">
                        <div><i class="fa-solid fa-bed"></i></div>
                        <p>Rooms</p>
                    </div>
                </a>
                <a href="/listings?category=iconic cities">
                    <div class="filter icon-item">
                        <div><i class="fa-solid fa-mountain-city"></i></div>
                        <p>Iconic Cities</p>
                    </div>
                </a>
                <a href="/listings?category=mountains">
                    <div class="filter icon-item">
                        <div><i class="fa-solid fa-mountain"></i></div>
                        <p>Mountains</p>
                    </div>
                </a>
                <a href="/listings?category=castles">
                    <div class="filter icon-item">
                        <div><i class="fa-brands fa-fort-awesome"></i></div>
                        <p>Castles</p>
                    </div>
                </a>
                <a href="/listings?category=amazing pools">
                    <div class="filter more-icon">
                        <div><i class="fa-solid fa-person-swimming"></i></i></div>
                        <p>Amazing Pools</p>
                    </div>
                </a>
                <a href="/listings?category=camping">
                    <div class="filter more-icon">
                        <div><i class="fa-solid fa-campground"></i></div>
                        <p>Camping</p>
                    </div>
                </a>
                <a href="/listings?category=farms">
                    <div class="filter more-icon">
                        <div><i class="fa-solid fa-cow"></i></div>
                        <p>Farms</p>
                    </div>
                </a>
                <a href="/listings?category=domes">
                    <div class="filter more-icon">
                        <div><i class="fa-solid fa-igloo"></i></div>
                        <p>Domes</p>
                    </div>
                </a>
                <a href="/listings?category=arctic">
                    <div class="filter more-icon">
                        <div><i class="fa-brands fa-fort-awesome"></i></div>
                        <p>Arctic</p>
                    </div>
                </a>
                <a href="/listings?category=boats">
                    <div class="filter more-icon">
                        <div><i class="fa-solid fa-ferry"></i></div>
                        <p>Boats</p>
                    </div>
                </a>

                <div id="show-more">
                    <i class="fa-solid fa-angle-right"></i>
                </div>
            </div>

            <div class="tax-toggle">
                <div class="form-check form-check-reverse form-switch togg">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>
        <div class="row row-cols-lg-3 row-cols-1 row-cols-md-2 row-cols-sm-1 mt-3">
            <%for(let listing of allListings) {%>
                <div class="card col listing-card">
                    <a href="/listings/<%= listing._id %>" class="listing-link">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                            style="height: 20rem">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= listing.title %>
                                </b><br>
                                &#8377; <%=listing.price.toLocaleString("en-IN") %> / night
                                    <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
                            </p>
                        </div>
                    </a>
                </div>
                <br>
                <%}%>
        </div>

        <script>
            let taxSwitch = document.getElementById("switchCheckDefault");
            taxSwitch.addEventListener("change", () => {
                let taxInfo = document.getElementsByClassName("tax-info");
                for (let info of taxInfo) {
                    info.style.display = taxSwitch.checked ? "inline" : "none"
                }
            });

            const showMore = document.getElementById("show-more");
            const iconItem = document.querySelectorAll(".icon-item")
            const moreIcons = document.querySelectorAll(".more-icon");
            let expanded = false;
            showMore.addEventListener("click", (event) => {
                expanded = !expanded;
                iconItem.forEach((el) => {
                    el.style.display = expanded ? "none" : "inline-block";
                })
                moreIcons.forEach(element => {
                    element.style.display = expanded ? "inline-block" : "none";
                });
            });

        </script>